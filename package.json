    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lefthook": "^1.7.0",
    "semantic-release": "^24.0.0"
