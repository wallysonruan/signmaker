{
  "name": "@wallysonruan/signmaker-vue",
  "version": "1.4.0",
  "description": "Vue 3 composables and components for the SignWriter editor.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wallysonruan/signmaker.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@wallysonruan/signmaker-editor-engine": "file:../editor",
    "@wallysonruan/signmaker-interactions": "file:../interactions",
    "@wallysonruan/signmaker-renderer": "file:../renderer",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.0.0",
    "vue-tsc": "^3.3.4"
  }
}
